# Copy this file to keystore.properties and fill in the values.
# Do NOT commit keystore.properties or your .keystore file to git.
# Back up the keystore file and these passwords securely (e.g. 1Password, Google Drive).
# If you lose them, you cannot publish updates to the same app on Play Store.
#
# Generate the keystore once (see docs/ANDROID_RELEASE_BUILD.md):
#   keytool -genkeypair -v -storetype PKCS12 -keystore until-release.keystore -alias until -keyalg RSA -keysize 2048 -validity 10000
#
# Path is relative to android/app/ (where this file lives).
storeFile=until-release.keystore
storePassword=YOUR_STORE_PASSWORD
keyAlias=until
keyPassword=YOUR_KEY_PASSWORD
